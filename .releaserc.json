{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/github", {
      "assets": [
        {"path": "dist-artifacts/dev-workflow-*.tar.gz", "label": "${name}"},
        {"path": "dist-artifacts/dev-workflow-*.zip", "label": "${name}"},
        {"path": "dist-artifacts/dev-workflow-*.sha256", "label": "${name}"}
      ]
    }]
  ]
}
