{
  "name": "@dev-workflow/cli",
  "version": "0.1.0",
  "description": "CLI for dev-workflow system",
  "type": "module",
  "bin": {
    "dev-workflow": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-static",
    "copy-static": "mkdir -p dist/ui && cp -r src/ui/public dist/ui/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dev-workflow/mcp-server": "workspace:*",
    "@fastify/static": "^8.0.3",
    "commander": "^12.0.0",
    "fastify": "^5.2.1",
    "get-port": "^7.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
