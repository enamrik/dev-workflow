{
  "name": "@dev-workflow/local-workers",
  "version": "0.1.0",
  "description": "Local worker backend with SQLite queue",
  "type": "module",
  "exports": {
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dev-workflow/dispatch": "workspace:*",
    "@dev-workflow/git": "workspace:*",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.36.0",
    "@dev-workflow/database": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
