{
  "name": "@dev-workflow/core",
  "version": "0.1.0",
  "description": "Core domain logic for dev-workflow",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./domain/*": "./dist/domain/*.js",
    "./application/*": "./dist/application/*.js",
    "./infrastructure/*": "./dist/infrastructure/*.js",
    "./infrastructure/di": "./dist/infrastructure/di/index.js",
    "./schema": "./dist/infrastructure/database/schema.js",
    "./schema-pg": "./dist/infrastructure/database/schema-pg.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "mkdir -p dist/drizzle && cp -r drizzle/* dist/drizzle/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.962.0",
    "@aws-sdk/credential-providers": "^3.962.0",
    "@neondatabase/serverless": "^1.0.2",
    "awilix": "^12.0.5",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.36.0",
    "fastest-levenshtein": "^1.0.16",
    "js-yaml": "^4.1.1",
    "sql.js": "^1.10.3",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@types/sql.js": "^1.4.9",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
