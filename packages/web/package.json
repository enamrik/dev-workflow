{
  "name": "@dev-workflow/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev -p ${PORT:-3457}",
    "build": "next build && pnpm build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "next start -p ${PORT:-3456}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dev-workflow/core": "workspace:*",
    "@tanstack/react-query": "^5.17.0",
    "better-sqlite3": "^12.5.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.2.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.2.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.5.10",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
