{
  "name": "@dev-workflow/tracking",
  "version": "0.1.0",
  "description": "Issue tracking domain: issues, plans, tasks, milestones, and external sync",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dev-workflow/database": "workspace:*",
    "@dev-workflow/effect": "workspace:*",
    "@dev-workflow/dispatch": "workspace:*",
    "@dev-workflow/git": "workspace:*",
    "@dev-workflow/local-workers": "workspace:*",
    "@aws-sdk/client-s3": "^3.962.0",
    "@aws-sdk/credential-providers": "^3.962.0",
    "@neondatabase/serverless": "^1.0.2",
    "awilix": "^12.0.5",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.36.0",
    "fastest-levenshtein": "^1.0.16",
    "js-yaml": "^4.1.1",
    "sql.js": "^1.10.3",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
